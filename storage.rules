rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && request.auth.token.email == 'ronnywoods77@gmail.com';
    }

    match /cleaner-cvs/{userId}/{fileName} {
      allow write: if signedIn() && request.auth.uid == userId;
      allow read: if isOwner() || (signedIn() && request.auth.uid == userId);
    }
  }
}
